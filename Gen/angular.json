{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "b18c744d-b396-4470-953d-e1e7201eb9c5"
  },
  "newProjectRoot": "projects",
  "projects": {
    "Gen": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
               "src/assets",
               "src/facicon",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/material-theme.scss",
             "src/styles.css",
             "node_modules/bootstrap/dist/css/bootstrap.min.css"
            ],
            "scripts": [
  "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": []
            },
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
           "production": {
    "optimization": true,
    "outputHashing": "all",
    "sourceMap": false,
    "extractLicenses": true,
    "namedChunks": false
  },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "Gen:build:production"
            },
            "development": {
              "buildTarget": "Gen:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
